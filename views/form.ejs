<!DOCTYPE html>
<html lang="en">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title><%= product ? 'Edit Product' : 'Add Product' %></title>
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6 card p-4 shadow">
                <h3 class="mb-4 text-center"><%= product ? 'Edit Product' : 'Add New Product' %></h3>
                <form action="<%= product ? '/edit' : '/add' %>" method="POST" enctype="multipart/form-data">
                    <% if (product) { %>
                        <input type="hidden" name="id" value="<%= product.id %>">
                        <input type="hidden" name="old_image" value="<%= product.image %>">
                    <% } %>

                    <div class="mb-3">
                        <label class="form-label">Product Name</label>
                        <input type="text" name="name" class="form-control" value="<%= product ? product.name : '' %>" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Category</label>
                        <input type="text" name="category" class="form-control" value="<%= product ? product.category : '' %>">
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Price (฿)</label>
                            <input type="number" name="price" class="form-control" min="0" step="0.01" value="<%= product ? product.price : '' %>" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Stock</label>
                            <input type="number" name="stock" class="form-control" min="0" value="<%= product ? product.stock : '' %>" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Product Image</label>
                        <input type="file" name="image" class="form-control" accept="image/*">
                        <% if (product && product.image) { %>
                            <div class="mt-2 text-center">
                                <p class="small text-muted">Current image:</p>
                                <img src="/uploads/<%= product.image %>" width="100" class="rounded shadow-sm">
                            </div>
                        <% } %>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-success">Save Product</button>
                        <a href="/" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>