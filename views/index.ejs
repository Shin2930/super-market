<!DOCTYPE html>
<html lang="en">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Supermarket Admin</title>
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container">
            <span class="navbar-brand">Supermarket Admin</span>
            <a href="/add" class="btn btn-primary">Add New Product</a>
        </div>
    </nav>

    <div class="container">
        <% if (success) { %>
            <div class="alert alert-success">Operation successfully!</div>
        <% } %>

        <div class="row">
            <% products.forEach(p => { %>
                <div class="col-md-3 mb-4">
                    <div class="card h-100 shadow-sm">
                        <img src="/uploads/<%= p.image %>" class="card-img-top" style="height: 200px; object-fit: cover;">
                        <div class="card-body">
                            <h5 class="card-title"><%= p.name %></h5>
                            <p class="text-muted small"><%= p.category %></p>
                            <p class="fw-bold text-primary">฿<%= p.price %></p>
                            
                            <p>Stock: 
                                <span class="<%= p.stock == 0 ? 'text-danger fw-bold' : '' %>">
                                    <%= p.stock == 0 ? 'Out of Stock' : p.stock %>
                                </span>
                            </p>

                            <div class="d-flex justify-content-between">
                                <a href="/edit/<%= p.id %>" class="btn btn-warning btn-sm text-white">Edit</a>
                                <button class="btn btn-danger btn-sm" onclick="confirmDelete('<%= p.id %>')">Delete</button>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <script>
        function confirmDelete(id) {
            if (confirm("คุณแน่ใจหรือไม่ว่าต้องการลบรายการนี้?")) {
                window.location.href = "/delete/" + id;
            }
        }
    </script>
</body>
</html>